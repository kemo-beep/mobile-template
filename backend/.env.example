# Environment variables for Mobile Backend API (reference only)
# For local dev: copy .dev.vars.example to .dev.vars (Wrangler loads .dev.vars)
# For production: use `wrangler secret put <KEY>` for each secret

# ─── Required ───────────────────────────────────────────────────

# NeonDB connection string — get from https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Better Auth secret — min 32 chars (openssl rand -base64 32)
BETTER_AUTH_SECRET=your-secret-key-here

# Better Auth URL — public URL of this API
BETTER_AUTH_URL=http://localhost:8787

# ─── Optional (Production features) ──────────────────────────────

# Apple Sign-In — required for iOS App Store if offering social login
# APPLE_CLIENT_ID=your-apple-services-id
# APPLE_CLIENT_SECRET=your-apple-client-secret-jwt

# Google OAuth — for web/analytics sign-in
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# Redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# CORS — comma-separated allowed origins (production)
# ALLOWED_ORIGINS=https://your-app.com,https://app.your-domain.com,myapp://

# Push Notifications (FCM for Android)
# FCM_PROJECT_ID=your-firebase-project-id
# FCM_CLIENT_EMAIL=firebase-adminsdk-xxx@project.iam.gserviceaccount.com
# FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Push Notifications (APNs for iOS)
# APNS_KEY_ID=your-key-id
# APNS_TEAM_ID=your-team-id
# APNS_BUNDLE_ID=com.yourapp
# APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# APNS_PRODUCTION=false

# Logging / APM (Axiom)
# AXIOM_TOKEN=your-axiom-api-token
# AXIOM_DATASET=your-dataset-name

# Analytics data retention in days (default 90). No automated purge in MVP.
# ANALYTICS_RETENTION_DAYS=90
