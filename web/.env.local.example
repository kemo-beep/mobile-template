# Copy to .env.local. All vars are optional — buttons link to # if unset.

# App Store and Play Store links for the landing page download buttons
# Set these to your published app URLs when ready
# NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/your-app/id123456789
# NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.yourapp
