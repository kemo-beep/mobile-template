# Copy to .env for local development. Most vars are optional — the app has defaults.

# Backend API base URL (optional override)
# Default: localhost (simulator/web), 10.0.2.2 (Android emulator)
# For physical device: use your computer's LAN IP (e.g. http://192.168.1.x:8787)
# EXPO_PUBLIC_API_URL=http://localhost:8787

# Sentry DSN for crash reporting (optional)
# Get from https://sentry.io — create a project and copy the DSN
# EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# EAS project ID (optional, for Expo push token in development)
# EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
